#!/usr/bin/env bash
set -euo pipefail

# wt - git worktree manager for bare-clone layouts
#
# Usage:
#   wt                            List all worktrees
#   wt ls                         List all worktrees
#   wt main                       Enter main/ worktree (creates if needed)
#   wt new <name> [<start-point>] Create worktree for a new branch (default: origin/main)
#   wt add [<name>]               Create worktree for an existing branch
#   wt rm [<name>] [options]      Remove worktree and delete local branch
#   wt cd [<name>]                Enter a worktree by directory name
#   wt path [<name>]              Show path to a worktree
#   wt prune                      Clean up stale worktree references
#   wt help                       Show this help
#
# Requires a bare-clone layout created by 'git clone-bare-for-worktrees'.
# All worktrees are siblings of .bare/ in the project root.

# Find project root by walking up from cwd looking for .bare/ + .git pointer.
find_project_root() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.bare" ] && [ -f "$dir/.git" ]; then
            echo "$dir"
            return 0
        fi
        dir=$(dirname "$dir")
    done
    return 1
}

require_bare_layout() {
    local root
    if ! root=$(find_project_root); then
        echo "Error: Not in a bare-clone worktree layout." >&2
        echo "Set up a project with: git clone-bare-for-worktrees <url>" >&2
        exit 1
    fi
    echo "$root"
}

copy_env_files() {
    local root="$1" worktree_dir="$2"
    local main_dir="$root/main"
    [ -d "$main_dir" ] || return 0
    for f in .env .env.keys .env.local; do
        if [ -f "$main_dir/$f" ] && [ ! -f "$worktree_dir/$f" ]; then
            cp "$main_dir/$f" "$worktree_dir/$f"
            echo "wt: copied $f from main worktree" >&2
        fi
    done
}

validate_name() {
    local name="$1"
    if [[ "$name" == *".."* ]] || [[ "$name" == "/"* ]]; then
        echo "Error: Invalid worktree name '$name'" >&2
        exit 1
    fi
}

# List non-main worktree names (for fzf selection)
list_worktree_names() {
    local root="$1"
    git -C "$root" worktree list --porcelain 2>/dev/null | awk -v root="$root/" '
        /^worktree / {
            path = substr($0, 10)
            if (path != root && path !~ /\.bare$/) {
                sub(root, "", path)
                print path
            }
        }
    '
}

# Prompt user to select a worktree via fzf
select_worktree() {
    local root="$1" prompt="${2:-worktree}"
    if ! command -v fzf &>/dev/null || [ ! -t 0 ]; then
        return 1
    fi
    list_worktree_names "$root" | fzf --height=~50% --prompt="$prompt> " --select-1 --exit-0
}

# Prompt user to select a branch via fzf
select_branch() {
    local root="$1" prompt="${2:-branch}"
    if ! command -v fzf &>/dev/null || [ ! -t 0 ]; then
        return 1
    fi
    git -C "$root" branch -a --format='%(refname:short)' 2>/dev/null \
        | sed 's|^origin/||' | sort -u \
        | fzf --height=~50% --prompt="$prompt> " --select-1 --exit-0
}

cmd_main() {
    local root
    root=$(require_bare_layout)
    local worktree_dir="$root/main"

    if [ ! -d "$worktree_dir" ]; then
        if git -C "$root" show-ref --verify --quiet "refs/heads/main"; then
            git -C "$root" worktree add main main >&2
        else
            git -C "$root" worktree add main >&2
        fi
    fi

    echo "$worktree_dir"
}

local_branch_exists() {
    local root="$1" name="$2"
    git -C "$root" show-ref --verify --quiet "refs/heads/$name"
}

remote_branch_exists() {
    local root="$1" name="$2"
    git -C "$root" show-ref --verify --quiet "refs/remotes/origin/$name"
}

cmd_new() {
    if [ $# -lt 1 ]; then
        echo "Usage: wt new <name> [<start-point>]" >&2
        exit 1
    fi

    local name="$1"
    shift
    local start_point="${1:-origin/main}"
    validate_name "$name"

    local root
    root=$(require_bare_layout)
    local worktree_dir="$root/$name"

    if [ -d "$worktree_dir" ]; then
        echo "Error: Worktree already exists: $name" >&2
        exit 1
    fi

    if local_branch_exists "$root" "$name"; then
        echo "Error: Local branch '$name' already exists. Use 'wt add $name' instead." >&2
        exit 1
    fi

    if remote_branch_exists "$root" "$name"; then
        echo "Error: Remote branch 'origin/$name' already exists. Use 'wt add $name' instead." >&2
        exit 1
    fi

    git -C "$root" worktree add --no-track -b "$name" "$worktree_dir" "$start_point" >&2
    copy_env_files "$root" "$worktree_dir"
    echo "$worktree_dir"
}

cmd_add() {
    local root
    root=$(require_bare_layout)

    local name
    if [ $# -lt 1 ]; then
        name=$(select_branch "$root" "add branch") || { echo "Usage: wt add <name>" >&2; exit 1; }
    else
        name="$1"
    fi
    validate_name "$name"
    local worktree_dir="$root/$name"

    if [ -d "$worktree_dir" ]; then
        echo "Worktree already exists: $name" >&2
        echo "$worktree_dir"
        return 0
    fi

    if ! local_branch_exists "$root" "$name" && ! remote_branch_exists "$root" "$name"; then
        echo "Error: Branch '$name' not found locally or on origin. Use 'wt new $name' to create it." >&2
        exit 1
    fi

    git -C "$root" worktree add "$worktree_dir" "$name" >&2
    copy_env_files "$root" "$worktree_dir"
    echo "$worktree_dir"
}

cmd_rm() {
    local keep_branch=false
    local force=false
    local name=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --keep-branch) keep_branch=true; shift ;;
            -f|--force) force=true; shift ;;
            -*) echo "Unknown option: $1" >&2; exit 1 ;;
            *)  name="$1"; shift ;;
        esac
    done

    local root
    root=$(require_bare_layout)

    if [ -z "$name" ]; then
        name=$(select_worktree "$root" "rm") || { echo "Usage: wt rm <name> [--keep-branch]" >&2; exit 1; }
    fi

    validate_name "$name"

    if [ "$name" = "main" ]; then
        echo "Error: Cannot remove persistent worktree 'main'." >&2
        exit 1
    fi
    local worktree_dir="$root/$name"

    if [ ! -d "$worktree_dir" ]; then
        echo "Worktree not found: $name" >&2
        git -C "$root" worktree list >&2
        exit 1
    fi

    local remove_args=("$worktree_dir")
    if [ "$force" = true ]; then
        remove_args+=(--force)
    fi
    git -C "$root" worktree remove "${remove_args[@]}"

    if [ "$keep_branch" = false ]; then
        if git -C "$root" show-ref --verify --quiet "refs/heads/$name"; then
            echo "Deleting local branch: $name"
            git -C "$root" branch -D "$name"
        fi
    fi

    git -C "$root" worktree prune
}

cmd_cd() {
    local root
    root=$(require_bare_layout)

    local name
    if [ $# -lt 1 ]; then
        name=$(select_worktree "$root" "cd") || { echo "Usage: wt cd <name>" >&2; exit 1; }
    else
        name="$1"
    fi

    validate_name "$name"
    local worktree_dir="$root/$name"

    if [ ! -d "$worktree_dir" ]; then
        echo "Worktree not found: $name" >&2
        exit 1
    fi

    echo "$worktree_dir"
}

cmd_path() {
    cmd_cd "$@"
}

cmd_list() {
    local root
    root=$(require_bare_layout)
    git -C "$root" worktree list "$@"
}

cmd_prune() {
    local root
    root=$(require_bare_layout)
    git -C "$root" worktree prune "$@"
}

cmd_main_help() {
    cat <<'EOF'
Usage: wt main

Enter the main/ worktree, creating it if needed.
EOF
}

cmd_new_help() {
    cat <<'EOF'
Usage: wt new <name> [<start-point>]

Create a worktree for a new branch.

Arguments:
  <name>          Name for the new branch and worktree directory
  <start-point>   Starting commit (default: origin/main)
EOF
}

cmd_add_help() {
    cat <<'EOF'
Usage: wt add [<name>]

Create a worktree for an existing local or remote branch. If no name is given, uses fzf to select.

Arguments:
  <name>   Name of an existing branch to check out (optional with fzf)
EOF
}

cmd_rm_help() {
    cat <<'EOF'
Usage: wt rm [<name>] [--keep-branch] [--force]

Remove a worktree and delete its local branch. If no name is given, uses fzf to select.

Arguments:
  <name>          Worktree to remove (cannot be 'main'; optional with fzf)

Options:
  --keep-branch   Keep the local branch after removing the worktree
  -f, --force     Force removal even with modified or untracked files
EOF
}

cmd_ls_help() {
    cat <<'EOF'
Usage: wt ls

List all worktrees in the project.
EOF
}

cmd_cd_help() {
    cat <<'EOF'
Usage: wt cd [<name>]

Enter a worktree by directory name. If no name is given, uses fzf to select.

Arguments:
  <name>   Worktree directory to change into (optional with fzf)
EOF
}

cmd_path_help() {
    cat <<'EOF'
Usage: wt path [<name>]

Print the absolute path to a worktree. If no name is given, uses fzf to select.

Arguments:
  <name>   Worktree directory to locate (optional with fzf)
EOF
}

cmd_prune_help() {
    cat <<'EOF'
Usage: wt prune [options]

Clean up stale worktree references.

Removes worktree entries whose directories no longer exist on disk.

Options:
  -n, --dry-run          Show what would be removed without removing
  -v, --verbose          Report pruned worktree references
  --expire <time>        Only prune entries older than <time>
EOF
}

cmd_help() {
    cat <<'EOF'
wt - git worktree manager for bare-clone layouts

Usage:
  wt                            List all worktrees
  wt ls                         List all worktrees
  wt main                       Enter main/ worktree (creates if needed)
  wt new <name> [<start-point>] Create worktree for a new branch (default: origin/main)
  wt add [<name>]               Create worktree for an existing branch
  wt rm [<name>] [options]      Remove worktree and delete local branch
  wt cd [<name>]                Enter a worktree by directory name
  wt path [<name>]              Show path to a worktree
  wt prune                      Clean up stale worktree references
  wt help                       Show this help

Requires a bare-clone layout created by 'git clone-bare-for-worktrees'.
All worktrees are siblings of .bare/ in the project root.
EOF
}

# Hidden subcommand for zsh completions to get the project root.
cmd__root() {
    require_bare_layout
}

main() {
    if [ $# -eq 0 ]; then
        cmd_list
        exit 0
    fi

    local subcommand="$1"
    shift

    # Intercept --help/-h for any subcommand
    for arg in "$@"; do
        if [ "$arg" = "--help" ] || [ "$arg" = "-h" ]; then
            if type "cmd_${subcommand}_help" &>/dev/null; then
                "cmd_${subcommand}_help"
            else
                cmd_help
            fi
            exit 0
        fi
    done

    case "$subcommand" in
        main)           cmd_main "$@" ;;
        new)            cmd_new "$@" ;;
        add)            cmd_add "$@" ;;
        rm)             cmd_rm "$@" ;;
        ls)             cmd_list "$@" ;;
        cd)             cmd_cd "$@" ;;
        path)           cmd_path "$@" ;;
        prune)          cmd_prune "$@" ;;
        _root)          cmd__root ;;
        -h|--help|help) cmd_help ;;
        *)
            echo "Unknown command: $subcommand" >&2
            echo "Run 'wt help' for usage." >&2
            exit 1
            ;;
    esac
}

main "$@"
