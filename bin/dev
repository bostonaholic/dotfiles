#!/usr/bin/env bash
################################################################################
# dev - Start a development session
#
# DESCRIPTION:
#   Launches a tmux session named after the current git project with two
#   windows: one for your shell and one running Claude Code.
#
# USAGE:
#   dev [session-name]
#
# EXAMPLES:
#   cd ~/projects/myapp && dev   # Creates session "myapp"
#   dev myapp                    # Creates session "myapp" with explicit name
#   dev                          # Reattaches if session already exists
#
# DEPENDENCIES:
#   - tmux
#   - claude (Claude Code CLI)
#   - git (optional, falls back to directory name)
#
################################################################################

set -euo pipefail

if [[ "${1:-}" =~ ^(-h|--help)$ ]]; then
    sed -n '3,/^####/{/^####/d; s/^# \{0,1\}//; p;}' "$0"
    exit 0
fi

# Use argument as session name, or derive from git repo / current directory
if [ -n "${1:-}" ]; then
    session="$1"
elif git rev-parse --git-common-dir &>/dev/null; then
    # Uses git-common-dir to resolve the repo root, which works for
    # normal repos (.git) and repos with .worktrees/
    session=$(basename "$(dirname "$(cd "$(git rev-parse --git-common-dir)" && pwd)")")
else
    session=$(basename "$PWD")
fi

# Sanitize: tmux replaces dots and colons with underscores
session="${session//[.:]/_}"

# Reuse existing session
if tmux has-session -t "=$session" 2>/dev/null; then
    if [ -n "${TMUX:-}" ]; then
        exec tmux switch-client -t "=$session"
    else
        exec tmux attach-session -t "=$session"
    fi
fi

# Create session with first window named after the project
tmux new-session -d -s "$session" -c "$PWD"

# Create second window running Claude Code
tmux new-window -t "=$session:" -n "claude" -c "$PWD" "/opt/homebrew/bin/claude --dangerously-skip-permissions"

# Select the first window
tmux select-window -t "=$session:1"

# Attach or switch
if [ -n "${TMUX:-}" ]; then
    exec tmux switch-client -t "=$session"
else
    exec tmux attach-session -t "=$session"
fi
