#!/bin/bash
################################################################################
# Install Claude Code MCP Servers
#
# DESCRIPTION:
#   Registers MCP servers with Claude Code from dotfiles.yaml configuration.
#
# USAGE:
#   Called by install.sh, or run directly:
#   ./install_claude_mcp_servers
#
# ENVIRONMENT VARIABLES:
#   DRY_RUN  - If true, preview changes without making them (default: false)
#   VERBOSE  - If true, show detailed output (default: false)
#
# WHAT IT DOES:
#   1. Checks if claude CLI is installed, skips if not found
#   2. Reads MCP server list from packages.claude_mcp.servers in dotfiles.yaml
#   3. Registers each server using 'claude mcp add'
#   4. Reports statistics on servers registered
#
# DEPENDENCIES:
#   - claude CLI (skips if not installed)
#   - yq (for parsing YAML)
#   - dotfiles.yaml configuration file
#
################################################################################

set -euo pipefail

# shellcheck source=lib.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib.sh"

# Main function
main() {
    log "Installing Claude Code MCP servers..."

    # Check if claude CLI is available
    if ! command -v claude &> /dev/null; then
        warn "claude CLI not found. Skipping MCP server installation"
        warn "Install Claude Code first, then run: $0"
        return
    fi

    # Parse MCP servers from YAML using yq
    local server_count
    server_count=$(yq eval '.packages.claude_mcp.servers | length' "$CONFIG_FILE" 2>/dev/null || echo "0")

    if [[ "$server_count" == "0" ]]; then
        log "No MCP servers to install"
        return
    fi

    local installed=0
    local total=0

    for ((i=0; i<server_count; i++)); do
        local name command
        name=$(yq eval ".packages.claude_mcp.servers[$i].name" "$CONFIG_FILE" 2>/dev/null)
        command=$(yq eval ".packages.claude_mcp.servers[$i].command" "$CONFIG_FILE" 2>/dev/null)

        # Collect args into an array
        local args=()
        local arg_count
        arg_count=$(yq eval ".packages.claude_mcp.servers[$i].args | length" "$CONFIG_FILE" 2>/dev/null || echo "0")
        for ((j=0; j<arg_count; j++)); do
            args+=("$(yq eval ".packages.claude_mcp.servers[$i].args[$j]" "$CONFIG_FILE" 2>/dev/null)")
        done

        if [[ -n "$name" && -n "$command" ]]; then
            total=$((total + 1))
            if [[ $DRY_RUN == true ]]; then
                log "[DRY RUN] Would add MCP server: $name ($command ${args[*]:-})"
            else
                log "Adding MCP server: $name"
                # Remove existing server first (ignore errors if not found)
                claude mcp remove "$name" -s user 2>/dev/null || true
                if claude mcp add "$name" -s user "$command" "${args[@]}"; then
                    installed=$((installed + 1))
                    success "  ✓ $name registered"
                else
                    warn "  ✗ Failed to register $name"
                fi
            fi
        fi
    done

    if [[ $DRY_RUN == false ]]; then
        success "MCP servers: $installed/$total registered"
    else
        success "MCP servers checked: $total servers would be registered"
    fi
}

# Run if executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
